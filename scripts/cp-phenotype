#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if [[ -x "$ROOT_DIR/.venv-cp-phenotype/bin/python" ]]; then
  "$ROOT_DIR/.venv-cp-phenotype/bin/python" -m cp_phenotype.cli "$@"
else
  PYTHONPATH="$ROOT_DIR/src${PYTHONPATH:+:$PYTHONPATH}" python3 -m cp_phenotype.cli "$@"
fi
