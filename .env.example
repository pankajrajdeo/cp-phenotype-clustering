# Copy to .env and fill locally. Do not commit real credentials.
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SERVICE=

# Optional: set only when generating stable deidentified IDs for controlled sharing.
CP_PHENOTYPE_ID_SALT=

# Optional SSH variables for manual remote access. The pipeline does not require these.
SSH_USER=
SSH_PASSWORD=
